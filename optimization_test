#----------------------------------------------------------------------------------------------------
# PACKAGES
#----------------------------------------------------------------------------------------------------

using LinearAlgebra
using JuMP
using Plots
using Mosek
using MosekTools

#----------------------------------------------------------------------------------------------------
# GENERAL PARAMETERS AND DEFINITIONS
#----------------------------------------------------------------------------------------------------

d = 9
Оі = 1 / 2
Оә = 5
ПҒ = 8
Оө = 0.01
Оі = 2

P = binomial_distribution(d, 0.7)
one = [1 for i = 1:d+1]

C = distance_matrix(d)

#----------------------------------------------------------------------------------------------------
# GENERATE MODEL
#----------------------------------------------------------------------------------------------------

model = Model()
set_optimizer(model, Mosek.Optimizer)
set_silent(model)

# define variables
@variable(model, Q[1:d+1])
@variable(model, О“[1:d+1, 1:d+1])

# define constarints
@constraint(model, Q .вүҘ 0)
@constraint(model, sum(Q) == 1)       
     
@constraint(model, О“ .вүҘ 0)
@constraint(model, tr(C * О“) - Оө вүӨ 0)
@constraint(model, О“ * one .== P)
@constraint(model, О“' * one .== Q)

print(model)

#----------------------------------------------------------------------------------------------------

for Оё = 0:d
    println("Оё = ", Оё)
    X = (1/(d+1)) * ones(d+1)
    optimal_value = f(Оё, X)

    for k = 0:9
        # define objective
        @objective(model, Max, (-2 * Оі * (v(Оё) * v(Оё)') * X + Оі * v(Оё).^2 + v(Оё))' * Q)

        # solve 
        optimize!(model)

        S = value.(Q)

        О» = 2 / (2 + k)
        X = X + О» * (S - X)

        println(f(Оё, X) - optimal_value)
        optimal_value = f(Оё, X)
        println(string("Iteration ", string(k+1), ": "), optimal_value)
    end

    println()
end

#----------------------------------------------------------------------------------------------------
# ADDITIONAL FUNCTIONS
#----------------------------------------------------------------------------------------------------

function binomial_distribution(n, p)
    return [binomial(n, i) * p^i * (1-p)^(d - i) for i = 0:d]
end

function L(Оё, k)
    return Оә * Оё - ПҒ * min(Оё, k)
end

function v(Оё)
    return [L(Оё, k) for k = 0:d]
end

function distance_matrix(d)
    C = Matrix{Int64}(undef, d+1, d+1)

    for i = 1:d+1
        for j = 1:d+1
            C[i, j] = abs(i - j)
        end
    end

    return C
end

function f(Оё, P)
    return - Оі * P' * (v(Оё) * v(Оё)') * P + (Оі * v(Оё) .^ 2 + v(Оё))' * P
end